generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
  output          = "../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
}

// ═══════════════════════════════════════
// AUTH & USERS
// ═══════════════════════════════════════

model Organization {
  id                     String    @id @default(cuid())
  name                   String
  website                String?
  industry               String?
  subIndustry            String?
  description            String?
  size                   String?
  hqCity                 String?
  hqCountry              String?
  yearFounded            Int?
  mission                String?
  vision                 String?
  allowedDomains         String[]  @default([])
  setupComplete          Boolean   @default(false)
  insightLastRefreshedAt DateTime?
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt

  users              User[]
  products           Product[]
  markets            Market[]
  personas           Persona[]
  competitors        Competitor[]
  brandProfile       BrandProfile?
  skills             Skill[]
  contentAssets      ContentAsset[]
  contentPieces      GeneratedContent[]
  designBriefs       DesignBrief[]
  insights           IndustryInsight[]
  learningLogs       LearningLog[]
  knowledgeEntries   KnowledgeEntry[]
  knowledgeDocuments KnowledgeDocument[]
  integrations       Integration[]
  aiProviders        AIProviderConfig[]
  tokenUsageLogs     TokenUsageLog[]
  customRoles        CustomRole[]
  skillsV2           SkillV2[]
  featureRegistries  FeatureRegistry[]
  usageSignals       UsageSignal[]
  outputFingerprints OutputFingerprint[]
  coachTracks        CoachTrack[]
  coachEnrollments   CoachEnrollment[]
}

model User {
  id                String    @id @default(cuid())
  email             String    @unique
  name              String?
  password          String?
  image             String?
  role              String    @default("others")
  department        String?
  jobTitle          String?
  jobRole           String?
  onboarded         Boolean   @default(false)
  mustResetPassword Boolean   @default(false)
  inviteStatus      String?
  inviteToken       String?   @unique
  lastActiveAt      DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id])

  contentAssets     ContentAsset[]
  generatedContent  GeneratedContent[]
  conversations     Conversation[]
  designBriefs      DesignBrief[]
  tourProgress      TourProgress[]
  radarExportLogs   RadarExportLog[]
  radarActivityLogs RadarActivityLog[]
  emailSequenceJobs EmailSequenceJob[]
  linkedinCheckJobs LinkedinCheckJob[]
  coachProgress     CoachProgress[]
  coachEnrollment   CoachEnrollment?
}

// Tracks who exported what from Radar (Accounts/Contacts CSV download), and when — the export
// flow itself is a stateless CSV builder with no history of its own, unlike Upload's own
// upload_jobs table on radar's side.
model RadarExportLog {
  id        String   @id @default(cuid())
  userId    String
  type      String // "contacts" | "accounts"
  rowCount  Int
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([createdAt])
}

// Admin-only audit trail of write/run actions by radar users — edits, mark irrelevant/unmark,
// permanent delete, uploads, and Validate/Enrich/Check LinkedIn runs. Deliberately excludes
// read/browse activity (viewing Accounts/Contacts, filtering) — that's noisy and low-signal;
// this only logs things that change data or cost money (Apify/Instantly/Debounce calls).
model RadarActivityLog {
  id        String   @id @default(cuid())
  userId    String
  action    String // e.g. "edit_contact", "mark_irrelevant_accounts", "delete_contacts", "validate_send", "linkedin_check"
  summary   String // human-readable one-liner shown in the Logs tab
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([createdAt])
}

// A bulk/CSV/Radar Email Sequences generation run — one prospect can take 10-20+ seconds
// (web-search research + generation), so a few-hundred-row batch can run well past an hour.
// This makes that survive closing the tab/navigating away/refreshing: the batch runs
// server-side, resuming via a periodic cron tick (see the "continue" action in
// /api/email-sequences/jobs) instead of depending on one browser tab staying open and
// on-page the whole time, the way the original client-driven loop did.
model EmailSequenceJob {
  id             String   @id @default(cuid())
  organizationId String
  userId         String
  label          String?
  mode           String // "bulk" | "radar" — which source tab started this job
  status         String   @default("running") // running | done | error
  prospects      Json // Prospect[] — the full batch, fixed at start time
  config         Json // SequenceConfig used for every prospect in this batch
  results        Json     @default("[]") // ProspectResult[] — accumulates as rows complete
  processed      Int      @default(0)
  total          Int
  failCount      Int      @default(0) // consecutive continuation failures — see MAX_CONSECUTIVE_FAILS
  error          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([organizationId, status])
}

// Check LinkedIn (Radar) — each chunk is a real paid Apify call, so a few-hundred-URL run can
// take a while. This makes it survive closing the tab/navigating away, gives a Stop button, and
// keeps a history of past runs so results can be downloaded later — mirrors EmailSequenceJob's
// pattern (checkpoint after every chunk, resumable via "advance", cancellable).
model LinkedinCheckJob {
  id             String   @id @default(cuid())
  organizationId String
  userId         String
  label          String?
  status         String   @default("running") // running | done | cancelled | error
  urls           Json // string[] — full input list, fixed at start time
  scrapeMode     String // "basic" | "email"
  vertical       String
  results        Json     @default("[]") // LinkedInCheckRow[] — accumulates as chunks complete
  processed      Int      @default(0)
  total          Int
  matched        Int      @default(0)
  mismatched     Int      @default(0)
  notFound       Int      @default(0)
  created        Int      @default(0)
  uncertain      Int      @default(0)
  failCount      Int      @default(0) // consecutive chunk failures — see MAX_CONSECUTIVE_FAILS
  error          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([organizationId, status])
}

// Company-level web research (recent news + product type) is objective, public info about the
// TARGET company, not tied to which org is running Email Sequences or which specific prospect
// title/name is used — so this cache is global and keyed by the researched company/domain only,
// reused across every org, batch, and future run for that same company.
model WebsiteInsightCache {
  id        String   @id @default(cuid())
  key       String   @unique // "domain:acme.com" or "company:acme inc" — see websiteInsights.ts
  insights  String
  source    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
}

// ═══════════════════════════════════════
// KNOWLEDGE BASE
// ═══════════════════════════════════════

model Market {
  id             String          @id @default(cuid())
  name           String
  type           String          @default("primary")
  notes          String?
  organizationId String
  organization   Organization    @relation(fields: [organizationId], references: [id])
  products       ProductMarket[]
  createdAt      DateTime        @default(now())
}

model Product {
  id             String              @id @default(cuid())
  name           String
  description    String?
  category       String?
  classification String?
  scope          String              @default("global")
  features       String[]
  useCases       String?
  bundleParentId String?
  bundleParent   Product?            @relation("ProductBundle", fields: [bundleParentId], references: [id])
  bundleChildren Product[]           @relation("ProductBundle")
  organizationId String
  organization   Organization        @relation(fields: [organizationId], references: [id])
  markets        ProductMarket[]
  personas       ProductPersona[]
  competitors    ProductCompetitor[]
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
}

model ProductMarket {
  productId String
  marketId  String
  product   Product @relation(fields: [productId], references: [id])
  market    Market  @relation(fields: [marketId], references: [id])

  @@id([productId, marketId])
}

model ProductPersona {
  productId String
  personaId String
  product   Product @relation(fields: [productId], references: [id])
  persona   Persona @relation(fields: [personaId], references: [id])

  @@id([productId, personaId])
}

model ProductCompetitor {
  productId    String
  competitorId String
  product      Product    @relation(fields: [productId], references: [id])
  competitor   Competitor @relation(fields: [competitorId], references: [id])

  @@id([productId, competitorId])
}

model Persona {
  id             String           @id @default(cuid())
  title          String
  department     String?
  seniority      String?
  kras           String[]
  kpis           String[]
  painPoints     String?
  howWeHelp      String?
  contentPrefs   String[]
  organizationId String
  organization   Organization     @relation(fields: [organizationId], references: [id])
  products       ProductPersona[]
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
}

model Competitor {
  id             String              @id @default(cuid())
  name           String
  website        String?
  marketOverlap  String[]
  positioning    String?
  differentiator String?
  organizationId String
  organization   Organization        @relation(fields: [organizationId], references: [id])
  products       ProductCompetitor[]
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
}

model BrandProfile {
  id               String       @id @default(cuid())
  traits           String[]
  archetype        String?
  toneFormal       Int          @default(30)
  toneTechnical    Int          @default(25)
  toneSerious      Int          @default(35)
  toneCorporate    Int          @default(45)
  voiceDescription String?
  wordsWeUse       String[]
  wordsWeAvoid     String[]
  competitiveMoat  String?
  organizationId   String       @unique
  organization     Organization @relation(fields: [organizationId], references: [id])
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
}

model KnowledgeEntry {
  id             String       @id @default(cuid())
  category       String
  title          String
  content        String
  source         String       @default("wizard")
  isAIGenerated  Boolean      @default(false)
  isApproved     Boolean      @default(true)
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([organizationId, source, createdAt])
  @@index([organizationId, category])
}

// ═══════════════════════════════════════
// SKILLS ENGINE
// ═══════════════════════════════════════

model Skill {
  id             String       @id @default(cuid())
  name           String
  category       String
  linkedFeature  String
  instructions   String
  description    String?
  isActive       Boolean      @default(true)
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([organizationId, isActive])
}

// ═══════════════════════════════════════
// CONTENT LIBRARY
// ═══════════════════════════════════════

model ContentAsset {
  id                 String       @id @default(cuid())
  name               String
  fileName           String?
  fileUrl            String?
  fileType           String?
  fileSize           Int?
  fileHash           String?
  contentType        String?
  linkedUrl          String?
  sourceUrl          String?
  productTags        String[]
  marketTags         String[]
  personaTags        String[]
  competitorTags     String[]
  customTags         String[]
  brandScore         Float?
  scoreVoice         Float?
  scoreTerminology   Float?
  scoreMessaging     Float?
  scorePersonality   Float?
  scoreCompleteness  Float?
  scoreSuggestions   String[]
  scoreStatus        String       @default("pending")
  intelligenceStatus String       @default("pending") // "pending" | "extracting" | "done" | "failed"
  analyzedAt         DateTime?
  aiSummary          String?
  uploadedById       String
  uploadedBy         User         @relation(fields: [uploadedById], references: [id], onDelete: Cascade)
  organizationId     String
  organization       Organization @relation(fields: [organizationId], references: [id])
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt

  @@index([organizationId, createdAt])
  @@index([organizationId, fileHash])
}

// ═══════════════════════════════════════
// CONTENT GENERATOR
// ═══════════════════════════════════════

model GeneratedContent {
  id              String       @id @default(cuid())
  topic           String
  formats         String[]
  targetProduct   String?
  targetMarket    String?
  targetPersona   String?
  positionAgainst String?
  toneOverride    String?
  keyPoints       String?
  referenceAssets String[]
  outputs         Json         @default("{}")
  generatedById   String
  generatedBy     User         @relation(fields: [generatedById], references: [id], onDelete: Cascade)
  organizationId  String
  organization    Organization @relation(fields: [organizationId], references: [id])
  createdAt       DateTime     @default(now())

  @@index([organizationId, createdAt])
  @@index([generatedById, createdAt])
}

// ═══════════════════════════════════════
// AI ASSISTANT
// ═══════════════════════════════════════

model Conversation {
  id        String    @id @default(cuid())
  title     String?
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages  Message[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([userId, updatedAt])
}

model Message {
  id             String       @id @default(cuid())
  role           String
  content        String
  citations      Json?
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  createdAt      DateTime     @default(now())

  @@index([conversationId, createdAt])
}

// ═══════════════════════════════════════
// INDUSTRY INTELLIGENCE
// ═══════════════════════════════════════

model IndustryInsight {
  id             String       @id @default(cuid())
  signalType     String
  priority       String       @default("medium")
  relevanceScore Int          @default(50)
  title          String
  summary        String
  sourceUrl      String?
  sourceName     String?
  takeaway       String?
  tags           String[]
  addedToKB      Boolean      @default(false)
  kbCategories   String[]
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  createdAt      DateTime     @default(now())

  @@index([organizationId, createdAt])
}

model LearningLog {
  id               String       @id @default(cuid())
  sourceType       String
  title            String
  summary          String
  takeaway         String?
  kbCategories     String[]
  tags             String[]
  sourceDocumentId String?
  organizationId   String
  organization     Organization @relation(fields: [organizationId], references: [id])
  createdAt        DateTime     @default(now())

  @@index([organizationId, createdAt])
}

model KnowledgeDocument {
  id             String       @id @default(cuid())
  name           String
  fileName       String
  fileUrl        String
  fileType       String
  fileSize       Int?
  status         String       @default("processing")
  learningsCount Int          @default(0)
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  createdAt      DateTime     @default(now())
}

// ═══════════════════════════════════════
// TOKEN USAGE TRACKING
// ═══════════════════════════════════════

model TokenUsageLog {
  id             String       @id @default(cuid())
  feature        String // "assistant" | "content_generator" | "design_brief" | "seo" | "brand_review" | "content_analysis" | "knowledge" | "industry_insights" | "setup_wizard"
  model          String       @default("claude-sonnet-4-6")
  provider       String       @default("anthropic")
  inputTokens    Int          @default(0)
  outputTokens   Int          @default(0)
  totalTokens    Int          @default(0)
  userId         String?
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  createdAt      DateTime     @default(now())

  @@index([organizationId, createdAt])
  @@index([organizationId, feature])
}

// ═══════════════════════════════════════
// AI PROVIDER CONFIGURATION (BYOK)
// ═══════════════════════════════════════

model AIProviderConfig {
  id             String       @id @default(cuid())
  provider       String // "anthropic" | "openai" | "google"
  encryptedKey   String // AES-256-GCM encrypted API key
  keyHint        String? // last 4 chars for display, e.g. "...xK9m"
  isActive       Boolean      @default(true)
  modelOverride  String? // optional default model override
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@unique([organizationId, provider])
}

// ═══════════════════════════════════════
// INTEGRATIONS
// ═══════════════════════════════════════

model Integration {
  id             String       @id @default(cuid())
  type           String // "hubspot"
  portalId       String?
  accessToken    String?
  refreshToken   String?
  expiresAt      DateTime?
  syncStatus     String       @default("idle") // "idle" | "syncing" | "error"
  lastSyncAt     DateTime?
  lastSyncError  String?
  metadata       Json         @default("{}")
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@unique([organizationId, type])
}

// ═══════════════════════════════════════
// DESIGN BRIEF
// ═══════════════════════════════════════

model DesignBrief {
  id             String       @id @default(cuid())
  prompt         String
  platform       String?
  format         String?
  brief          Json         @default("{}")
  createdById    String
  createdBy      User         @relation(fields: [createdById], references: [id], onDelete: Cascade)
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  createdAt      DateTime     @default(now())
}

// ═══════════════════════════════════════
// CUSTOM ROLES
// ═══════════════════════════════════════

model CustomRole {
  id             String       @id @default(cuid())
  name           String
  slug           String
  description    String?
  color          String       @default("#6B7280")
  rank           Int          @default(1)
  permissions    Json         @default("{}")
  kbPermissions  Json         @default("{}")
  isBuiltIn      Boolean      @default(false)
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@unique([organizationId, slug])
}

// ═══════════════════════════════════════
// GUIDED TOURS / ONBOARDING
// ═══════════════════════════════════════

model TourProgress {
  id          String    @id @default(cuid())
  tourId      String
  status      String    @default("pending") // "pending" | "completed" | "dismissed"
  completedAt DateTime?
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt   DateTime  @default(now())

  @@unique([userId, tourId])
}

// ═══════════════════════════════════════
// SKILLS V2 — Entity-level, feature-scoped, self-evolving
// ═══════════════════════════════════════

model SkillV2 {
  id           String  @id @default(cuid())
  name         String
  instructions String
  description  String?
  version      Int     @default(1)

  scope    String // "entity" | "feature" | "global"
  category String // brand | product | persona | competitor | market | messaging | proof_point | industry | seo | general | format | tone

  entityType String? // "product" | "persona" | "market" | "competitor"
  entityId   String?

  featureKey String? // "content_generator" | "assistant" | "email_sequences" | "design_brief" | "brand_review" | "content_review" | "industry_insights" | "asset_analysis"

  isActive      Boolean @default(true)
  isSynthesized Boolean @default(false)
  confidence    Float   @default(0.5)
  sourceCount   Int     @default(0)

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])

  parentSkillId String?
  parentSkill   SkillV2?  @relation("SkillVersions", fields: [parentSkillId], references: [id])
  childVersions SkillV2[] @relation("SkillVersions")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organizationId, scope, category])
  @@index([organizationId, featureKey])
  @@index([organizationId, entityType, entityId])
}

model FeatureRegistry {
  id              String       @id @default(cuid())
  key             String
  name            String
  description     String?
  skillCategories String[]
  isActive        Boolean      @default(true)
  organizationId  String
  organization    Organization @relation(fields: [organizationId], references: [id])
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  @@unique([organizationId, key])
}

model UsageSignal {
  id             String       @id @default(cuid())
  signalType     String // "feedback_positive" | "feedback_negative" | "edit" | "used" | "discarded" | "regenerated"
  featureKey     String
  outputId       String?
  entityType     String?
  entityId       String?
  metadata       Json         @default("{}")
  userId         String?
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  createdAt      DateTime     @default(now())

  @@index([organizationId, featureKey, createdAt])
  @@index([organizationId, signalType])
}

model OutputFingerprint {
  id              String       @id @default(cuid())
  featureKey      String
  format          String?
  entityType      String?
  entityId        String?
  structureHash   String
  openingPattern  String?
  headingPatterns String[]     @default([])
  ctaPattern      String?
  outputId        String?
  organizationId  String
  organization    Organization @relation(fields: [organizationId], references: [id])
  createdAt       DateTime     @default(now())

  @@index([organizationId, featureKey, format, createdAt])
}

// ═══════════════════════════════════════
// HIVEMIND COACH — employee onboarding / enablement
//
// A curriculum auto-composed from the knowledge base: Track → Module → Lesson →
// Question. Reference materials for a lesson are derived LIVE from Asset Library
// tags (via entityType/entityId), never stored, so they can't go stale. Per-user
// CoachProgress tracks scores and completion. All FKs cascade on delete.
// ═══════════════════════════════════════

model CoachTrack {
  id             String        @id @default(cuid())
  key            String        // e.g. "gtm-foundation"
  name           String
  description    String?
  targetRole     String?       // null = everyone
  order          Int           @default(0)
  isActive       Boolean       @default(true)
  isGenerated    Boolean       @default(true)
  organizationId String
  organization   Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  modules        CoachModule[]
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@index([organizationId, order])
}

model CoachModule {
  id          String        @id @default(cuid())
  trackId     String
  track       CoachTrack    @relation(fields: [trackId], references: [id], onDelete: Cascade)
  domain      String        // "company" | "markets" | "products" | "use_cases" | "customers" | "competitors"
  name        String
  description String?
  order       Int           @default(0)
  lessons     CoachLesson[]

  @@index([trackId, order])
}

model CoachLesson {
  id           String          @id @default(cuid())
  moduleId     String
  module       CoachModule     @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  title        String
  whyItMatters String?
  keyPoints    String          // markdown
  entityType   String?         // "product" | "persona" | "market" | "competitor" — for live reference-material lookup
  entityName   String?         // matched against Asset Library tag arrays
  order        Int             @default(0)
  questions    CoachQuestion[]
  progress     CoachProgress[]
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  @@index([moduleId, order])
}

model CoachQuestion {
  id             String      @id @default(cuid())
  lessonId       String
  lesson         CoachLesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  type           String      // "mcq" | "short"
  prompt         String
  options        Json        @default("[]") // string[] for mcq
  correctIndex   Int?        // mcq correct option index
  expectedAnswer String?     // short-answer: grounded expected answer / rubric (never sent to the client)
  explanation    String?
  order          Int         @default(0)

  @@index([lessonId, order])
}

model CoachProgress {
  id             String      @id @default(cuid())
  userId         String
  user           User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  lessonId       String
  lesson         CoachLesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  status         String      @default("not_started") // "not_started" | "in_progress" | "completed"
  score          Int?        // best score 0-100
  attempts       Int         @default(0)
  lastAnswers    Json?       // last submission, for review
  completedAt    DateTime?
  organizationId String
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  @@unique([userId, lessonId])
  @@index([organizationId, userId])
}

// Coach is opt-in per user (not all users). An admin enrolls specific people;
// only enrolled users (plus admins/owners, who own the module) see the learning
// experience. One enrollment per user.
model CoachEnrollment {
  id             String       @id @default(cuid())
  userId         String       @unique
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  assignedById   String?
  createdAt      DateTime     @default(now())

  @@index([organizationId])
}
